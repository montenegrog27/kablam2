SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key

# Required. Branch where this Raspberry is installed.
BRANCH_ID=00000000-0000-0000-0000-000000000000

# Optional but recommended. Used as an extra safety filter.
TENANT_ID=00000000-0000-0000-0000-000000000000

# Printing mode:
# - device: writes raw ESC/POS to /dev/usb/lp0 or PRINT_DEVICE_PATH
# - usb: uses vendor/product IDs configured in Admin > Impresoras
PRINT_MODE=device
PRINT_DEVICE_PATH=/dev/usb/lp0

# Agent behavior
PRINT_TICKETS=false
POLL_INTERVAL_MS=15000
PRINTED_STATE_FILE=./printed-orders.json
